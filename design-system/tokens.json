    "spacing": {
      "screen-x":   { "value": "14", "type": "spacing", "description": "бічні поля екрана" },
      "card-pad":   { "value": "17", "type": "spacing" },
      "row-pad-y":  { "value": "11", "type": "spacing" },
      "row-pad-x":  { "value": "15", "type": "spacing" },
      "stack-gap":  { "value": "12", "type": "spacing", "description": "відступ між картками" }
