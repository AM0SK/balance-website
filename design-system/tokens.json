      "avatar":      { "value": "34", "type": "sizing" },
      "avatar-lg":   { "value": "76", "type": "sizing" },
      "icon-btn":    { "value": "30", "type": "sizing" },
      "chip":        { "value": "26", "type": "sizing" },
      "tab-icon":    { "value": "18", "type": "sizing" }
