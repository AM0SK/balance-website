      "near-black": { "value": "#020202", "type": "color", "description": "нижня точка градієнта" }
    },

    "category": {
      "a-carb":    { "value": "#CC9A3A", "type": "color", "description": "A · крупи та злаки" },
      "b-protein": { "value": "#C15C48", "type": "color", "description": "Б · білкові продукти" },
      "v-veg":     { "value": "#6A6488", "type": "color", "description": "В · овочі та гриби" },
      "g-fat":     { "value": "#5E72A6", "type": "color", "description": "Г · жири та соуси" },
      "d-dairy":   { "value": "#8B5FBF", "type": "color", "description": "Д · молочні" },
      "e-fruit":   { "value": "#C15C8A", "type": "color", "description": "Е · фрукти та ягоди" }
    }
