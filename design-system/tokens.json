{
  "$description": "Balance design tokens. Формат Tokens Studio for Figma (сумісний з W3C Design Tokens). Імпорт: плагін Tokens Studio → Import → цей файл. Набори light і dark підключаються як окремі Themes.",

  "global": {
    "font": {
      "family": {
        "value": "Nunito",
        "type": "fontFamilies",
        "description": "Variable 200–1000. Google Fonts. У макеті вшито як data URI через CSP артефактів; у реальному сайті підключати звичайним <link>."
      }
    },

    "typography": {
      "logo":    { "value": { "fontFamily": "Nunito", "fontSize": "15", "fontWeight": "700", "letterSpacing": "-2%" }, "type": "typography", "description": "Balance у шапці" },
      "h1":      { "value": { "fontFamily": "Nunito", "fontSize": "26", "fontWeight": "600", "letterSpacing": "-2%" }, "type": "typography", "description": "Заголовок екрана" },
      "h2":      { "value": { "fontFamily": "Nunito", "fontSize": "26", "fontWeight": "700", "letterSpacing": "-2%" }, "type": "typography", "description": "Головне число картки" },
      "h3":      { "value": { "fontFamily": "Nunito", "fontSize": "15", "fontWeight": "700", "letterSpacing": "-1%" }, "type": "typography", "description": "Заголовок картки та секції" },
      "display": { "value": { "fontFamily": "Nunito", "fontSize": "42", "fontWeight": "700", "letterSpacing": "-3%" }, "type": "typography", "description": "Велике число-показник" },
      "body1":   { "value": { "fontFamily": "Nunito", "fontSize": "13", "fontWeight": "700" }, "type": "typography", "description": "Назви продуктів і рядків" },
      "body2":   { "value": { "fontFamily": "Nunito", "fontSize": "12", "fontWeight": "400" }, "type": "typography", "description": "Другорядний текст, підписи" },
      "label":   { "value": { "fontFamily": "Nunito", "fontSize": "12", "fontWeight": "500", "letterSpacing": "6%", "textCase": "uppercase" }, "type": "typography", "description": "Мітка над числом у картці" },
      "value":   { "value": { "fontFamily": "Nunito", "fontSize": "13", "fontWeight": "700" }, "type": "typography", "description": "Числа у рядках і відсотки" },
      "button":  { "value": { "fontFamily": "Nunito", "fontSize": "12", "fontWeight": "600" }, "type": "typography", "description": "Текст усіх кнопок" },
      "tab":     { "value": { "fontFamily": "Nunito", "fontSize": "10", "fontWeight": "700" }, "type": "typography", "description": "Підпис у таб-барі" }
    },

    "radius": {
      "card": { "value": "24", "type": "borderRadius" },
      "row":  { "value": "18", "type": "borderRadius" },
      "chip": { "value": "9",  "type": "borderRadius" },
      "pill": { "value": "999", "type": "borderRadius" }
